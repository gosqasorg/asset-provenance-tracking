{
  "name": "@scalar/nuxt",
  "description": "Nuxt integration for Scalar API references",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "integrations/nuxt"
  },
  "keywords": [
    "api",
    "references",
    "nuxt",
    "docs",
    "postman alternative",
    "rest",
    "testing",
    "vue"
  ],
  "version": "0.5.20",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "vue": "^3.5.17",
    "@scalar/api-reference": "1.38.0",
    "@scalar/api-client": "2.8.0",
    "@scalar/types": "0.3.1",
    "@scalar/use-hooks": "0.2.5",
    "@scalar/workspace-store": "0.17.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.6.2",
    "@nuxt/eslint-config": "^0.7.3",
    "@nuxt/module-builder": "^1.0.1",
    "@nuxt/schema": "^4.0.0",
    "@nuxt/test-utils": "^3.19.2",
    "@types/node": "^22.9.0",
    "cross-env": "^7.0.3",
    "nuxt": "^4.1.0",
    "vite": "7.1.5",
    "vitest": "3.2.4"
  },
  "scripts": {
    "build": "cross-env NUXT_TELEMETRY_DISABLED=false pnpm dev:prepare && nuxt-module-build build",
    "dev": "pnpm dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxi prepare && nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "format": "scalar-format",
    "format:check": "scalar-format-check",
    "lint:check": "scalar-lint-check",
    "lint:fix": "scalar-lint-fix",
    "test:watch": "vitest watch",
    "types:check": "NUXT_TELEMETRY_DISABLED=true nuxi typecheck"
  }
}